# Raw customer data - kept local even in private repo
data/projects/*/

# Manual data entry (solar/hours) — INTENTIONALLY TRACKED so it syncs to
# Streamlit Cloud and survives redeploy. Repo MUST stay private.
# Stored under data/manual/** (parquet + xlsx mirror + import_log.xlsx).
!data/manual/

# master.parquet (processed) is pushed so Streamlit Cloud renders the data.
# site_tracking.parquet too (operational tracking from xlsx).
# fuel_tracker.parquet too (rich fuel-log from "מעקב סולר וטיפולים" xlsx).
# Repo MUST stay private — contains financial and operational data.
# data/master.parquet         ← intentionally tracked
# data/site_tracking.parquet  ← intentionally tracked
# data/fuel_tracker.parquet   ← intentionally tracked

# SQLite audit log — local-only working state, rebuilt on each build_master.
data/audit.sqlite3
data/audit.sqlite3-journal
data/audit.sqlite3-wal
data/audit.sqlite3-shm

# project_control.sqlite — user-entered field data.
# INTENTIONALLY TRACKED: needs to sync to Streamlit Cloud so the dashboard
# shows manual entries. Side journals stay local.
# data/project_control.sqlite  ← intentionally tracked
data/project_control.sqlite-journal
data/project_control.sqlite-wal
data/project_control.sqlite-shm

# Database backups directory — local-only, can grow large.
data/backups/

# Outputs
output/
logs/

# Python
__pycache__/
*.py[cod]
*.so
*.egg-info/
.pytest_cache/

# Env
.env
.env.local

# Claude Code working dirs (worktrees etc) — local only, never deploy.
.claude/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# Streamlit local secrets
.streamlit/secrets.toml
