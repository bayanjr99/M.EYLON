# Raw customer data - kept local even in private repo
data/projects/*/

# master.parquet (processed) is pushed so Streamlit Cloud renders the data.
# site_tracking.parquet too (operational tracking from xlsx).
# Repo MUST stay private — contains financial and operational data.
# data/master.parquet         ← intentionally tracked
# data/site_tracking.parquet  ← intentionally tracked

# SQLite audit log — local-only working state, rebuilt on each build_master.
data/audit.sqlite3
data/audit.sqlite3-journal
data/audit.sqlite3-wal
data/audit.sqlite3-shm

